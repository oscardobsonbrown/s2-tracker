{
  "name": "app",
  "version": "0.4.5",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "analyze": "ANALYZE=true npm run build",
    "dev:flights": "FLIGHTS_PYTHON_BIN=.venv/bin/python next dev -p 3000",
    "python:setup": "python3 -m venv .venv && .venv/bin/python -m pip install -r requirements.txt",
    "test": "NODE_ENV=test vitest run",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@repo/analytics": "workspace:*",
    "@repo/auth": "workspace:*",
    "@repo/database": "workspace:*",
    "@repo/design-system": "workspace:*",
    "@repo/email": "workspace:*",
    "@repo/feature-flags": "workspace:*",
    "@repo/next-config": "workspace:*",
    "@repo/notifications": "workspace:*",
    "@repo/observability": "workspace:*",
    "@repo/security": "workspace:*",
    "@repo/seo": "workspace:*",
    "@repo/webhooks": "workspace:*",
    "@t3-oss/env-nextjs": "^0.13.8",
    "fuse.js": "^7.1.0",
    "import-in-the-middle": "^2.0.0",
    "lucide-react": "^0.556.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "require-in-the-middle": "8.0.1",
    "server-only": "^0.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@repo/testing": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "agentation": "^3.0.2",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^6.0.2",
    "vitest": "^4.0.15"
  }
}
